# ── Gmail & Google Sheets ─────────────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GOOGLE_SHEET_ID=                        # Spreadsheet ID from the sheet URL

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...            # console.anthropic.com

# ── Apify (Zillow scraping) ───────────────────────────────────────────────────
APIFY_TOKEN=apify_api_...               # console.apify.com → Settings → Integrations
APIFY_SOLD_COMPS_ACTOR_ID=crawlerbros~zillow-scraper  # Optional — sold comps only on price/value questions
SOLD_COMPS_MAX_RESULTS=2                # Hard cap for paid sold-comps results

# ── Team config ───────────────────────────────────────────────────────────────
TEAM_NAME=Austin Realty
TEAM_LEAD_EMAIL=lead@yourbrokerage.com
PROPERTY_MANAGER_EMAIL=                 # Optional — rental inquiries route here if set

# ── Scheduling ────────────────────────────────────────────────────────────────
CALENDLY_URL=https://calendly.com/your-name/30min

# ── Inquiry email add-ons ─────────────────────────────────────────────────────
ENABLE_SIMILAR_HOMES=false              # Optional — append similar-home cards to single-property inquiry replies
SIMILAR_HOMES_MAX=3                     # 1-6 cards
SIMILAR_HOMES_PRICE_VARIANCE=0.25       # +/- price band around the source listing

# ── Agent Inbox / channel flags ───────────────────────────────────────────────
ENABLE_EMAIL_AGENT=true
ENABLE_SMS_AGENT=false
ENABLE_WHATSAPP_AGENT=false
ENABLE_VOICE_AGENT=false
ENABLE_WEBSITE_CHAT_AGENT=false
ENABLE_AGENT_INBOX=true
AGENT_INBOX_PORT=8787
CLIENT_ID=default
CLIENT_NAME="Default Client"
DATABASE_URL=                          # Optional Postgres/Supabase URL. Dashboard uses DB first when set.
DATABASE_SSL=true
NEON_PROJECT_NAME=real-estate-agent-inbox
NEON_REGION_ID=aws-us-east-1
NEON_DATABASE_NAME=agent_os
NEON_ROLE_NAME=agent_os_app
NEON_API_KEY=                          # Neon API key for CLI/API bootstrap
NEON_ORG_ID=                           # Optional if using a personal Neon key with multiple orgs

# ── Seller valuation form ─────────────────────────────────────────────────────
FILLOUT_VALUATION_URL=                  # Optional — Fillout/Typeform property appraisal link

# ── CRM ───────────────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=                   # HubSpot private app access token (preferred)
HUBSPOT_API_KEY=                        # Legacy fallback; use HUBSPOT_ACCESS_TOKEN for new setup
GHL_PRIVATE_INTEGRATION_TOKEN=          # GoHighLevel sub-account private integration token
GHL_LOCATION_PIT=                       # Alias supported for the GoHighLevel private integration token
GHL_LOCATION_ID=                        # GoHighLevel sub-account location ID
GHL_SYNC_MODE=dry-run                   # dry-run | live
GHL_CONTACT_TAG=lumenosis-agent-os
GHL_CONVERSATION_PROVIDER_ID=           # Optional if using a custom provider

# ── SMS alerts (Twilio) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=                     # console.twilio.com
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1xxxxxxxxxx                # Your Twilio number
TWILIO_MESSAGING_SERVICE_SID=           # Optional. Prefer this for RCS-capable Messaging Service send/fallback
AGENT_PHONE=+1xxxxxxxxxx                # Number that receives hot-lead SMS texts
ENABLE_SMS_IMAGES=false                 # Send MMS property photos when Theo has a safe photo URL
SMS_IMAGE_MODE=on_request               # off | on_request | property_reply
SMS_MAX_IMAGES=3                        # Max one photo per requested property, capped at 3
THEO_ENRICHMENT_TIMEOUT_MS=14000        # Live data budget so SMS photo/detail lookups can return before reply
THEO_APIFY_TIMEOUT_SECONDS=12           # Per-Apify actor timeout for live SMS enrichment
GOOGLE_MAPS_API_KEY=                    # Optional Street View fallback when Zillow photos are unavailable

# ── Free data enrichment APIs ─────────────────────────────────────────────────
RENTCAST_API_KEY=                       # app.rentcast.io — free 50 req/month
FRED_API_KEY=                           # fred.stlouisfed.org — free, no limit
CENSUS_API_KEY=                         # api.census.gov/data/key_signup.html — free

# ── Polling interval ──────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60

# ── Aria voice agent (Vapi) ───────────────────────────────────────────────────
VAPI_API_KEY=                           # dashboard.vapi.ai → API Keys
VAPI_ASSISTANT_ID=                      # Set after `npm run aria:provision`
VAPI_PHONE_NUMBER_ID=                   # Vapi phone number bound to Aria
PUBLIC_BASE_URL=                        # https://your-app.com — base for Vapi tool/server webhooks
CALENDAR_TIMEZONE=America/Chicago       # Lead-local time for call-window + scheduling
ARIA_VOICE_ID=                          # Optional custom Vapi TTS voice id (per client)
HUMAN_TRANSFER_NUMBER=+15128152032      # Live transfer destination (must differ from the AI-answered number)
ARIA_CLASSIFY_MODEL=claude-haiku-4-5
ARIA_RESPOND_MODEL=gpt-5-mini
ARIA_ENRICHMENT_TIMEOUT_MS=3500         # Tight live-data budget mid-call; cache-first, SMS fallback on timeout

# ── Per-client agent config ───────────────────────────────────────────────────
AGENT_NAME_EMAIL=Iris
AGENT_NAME_SMS=Theo
AGENT_NAME_VOICE=Aria
AGENT_NAME_CHAT=Olivia
BRAND_VOICE=                            # Optional brand voice description injected into prompts
CRM_PROVIDER=ghl                        # ghl (live) | fub | kvcore | lofty (future adapters)
GHL_CALENDAR_ID=                        # Calendar used for showings (book/cancel/reschedule)

# ── Shared cadence (channel-aware, non-aggressive) ────────────────────────────
CADENCE_MAX_TOUCHES=14
CADENCE_MIN_GAP_HOURS=48
CADENCE_STOP_ON_REPLY=true
CADENCE_ONE_CHANNEL_PER_DAY=true
CADENCE_CALL_WINDOW_START_HOUR=8        # TCPA-safe call window (lead local time)
CADENCE_CALL_WINDOW_END_HOUR=21

# ── Agent notifications (channel-aware) ───────────────────────────────────────
NOTIFY_PREFERRED_CHANNEL=sms            # sms | email | dashboard
NOTIFY_QUIET_START_HOUR=21
NOTIFY_QUIET_END_HOUR=8

# ── Few-shot style training (Iris/Theo/Aria) ──────────────────────────────────
ENABLE_STYLE_TRAINING=false             # Off → agents behave exactly as today
STYLE_TRAINING_EXAMPLES_LIMIT=3
