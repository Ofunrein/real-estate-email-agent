# ============================================================
# Lumenosis Agent OS — Client Configuration Template
# Copy this file to clients/{client-id}.env, fill it out,
# then run: npm run aria:provision to deploy Iris for this client.
# ============================================================

# ── Identity ─────────────────────────────────────────────────
CLIENT_ID=                        # e.g. austin-realty, simon-team, apex-group
CLIENT_NAME=                      # e.g. "Austin Realty" (shown in SMS, emails)
AGENT_NAME_VOICE=Iris             # Caller-facing voice agent name
ARIA_CLIENT_NAME=                 # Optional: override displayed company name on calls
TEAM_NAME=                        # e.g. "Austin Realty" (internal label)
TEAM_LEAD_EMAIL=                  # Agent/broker email for notifications
AGENT_PHONE=                      # Agent's cell for Slack/SMS booking alerts
HUMAN_TRANSFER_NUMBER=            # Phone number Iris transfers sensitive calls to (E.164: +1...)
CALENDLY_URL=                     # Optional: fallback Calendly link if calendar booking fails

# ── Voice (Vapi) ─────────────────────────────────────────────
VAPI_API_KEY=                     # Vapi API key (one per client OR shared org key)
VAPI_ASSISTANT_ID=                # Set AFTER first provision (npm run aria:provision creates it)
VAPI_PHONE_NUMBER_ID=             # Vapi phone number bound to this assistant
VAPI_PUBLIC_KEY=                  # Vapi public key (for client-side SDK if used)
ARIA_VOICE_PROVIDER=openai        # openai | 11labs | azure | lmnt
ARIA_VOICE_ID=nova                # Voice ID for provider (e.g. "nova", "21m00Tcm4TlvDq8ikWAM")
ARIA_VOICE_MODEL=                 # Optional: override voice model (11labs: eleven_flash_v2_5)
ARIA_RESPOND_MODEL=gpt-4.1-mini  # LLM model for Iris reasoning
ARIA_CALLBACK_NUMBER=             # Number Iris gives callers to call back (defaults to TWILIO_FROM)
ARIA_AGENT_CONFIRMATION_PHONE=    # Agent cell that receives booking SMS alerts
BRAND_VOICE=                      # e.g. "Warm, direct, knowledgeable. Represents a boutique Austin team."

# ── Calendar ─────────────────────────────────────────────────
# CALENDAR_PROVIDER: google | outlook | ghl | neon
# google = Google Calendar (recommended default)
# outlook = Microsoft Outlook via Graph API
# ghl = GoHighLevel calendar
# neon = internal Postgres calendar (fallback, no external API)
CALENDAR_PROVIDER=google

# Google Calendar (set if CALENDAR_PROVIDER=google)
GOOGLE_CLIENT_ID=                 # From Google Cloud Console OAuth 2.0 client
GOOGLE_CLIENT_SECRET=             # From Google Cloud Console OAuth 2.0 client
GOOGLE_REFRESH_TOKEN=             # Run: npm run setup:google-calendar to generate
GOOGLE_CALENDAR_ID=               # e.g. agent@clientdomain.com or "primary"

# Outlook Calendar (set if CALENDAR_PROVIDER=outlook)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
OUTLOOK_REFRESH_TOKEN=            # Run: node scripts/setup-outlook-auth.mjs to generate
OUTLOOK_CALENDAR_ID=              # Leave empty for primary calendar

# Calendar behavior (applies to all providers)
CALENDAR_TIMEZONE=America/Chicago # IANA timezone for the client's market
GOOGLE_CALENDAR_SLOT_DURATION=30  # Default appointment length in minutes
GOOGLE_CALENDAR_MINIMUM_NOTICE_MINUTES=60  # Min lead time before a slot is bookable

# ── CRM ──────────────────────────────────────────────────────
# CRM_PROVIDER: ghl | kvcore | fub | none
CRM_PROVIDER=ghl

# GoHighLevel (set if CRM_PROVIDER=ghl)
GHL_PRIVATE_INTEGRATION_TOKEN=    # GHL Location Private Integration Token
GHL_LOCATION_ID=                  # GHL Location ID
GHL_CALENDAR_ID=                  # GHL Calendar ID for bookings
GHL_LOCATION_PIT=                 # Alternative to GHL_PRIVATE_INTEGRATION_TOKEN
GHL_CONTACT_TAG=lumenosis-agent-os
GHL_SYNC_MODE=live                # live | dry-run (dry-run logs only, no writes)

# KvCORE / Lofty (set if CRM_PROVIDER=kvcore)
KVCORE_API_KEY=
KVCORE_BASE_URL=                  # Default: https://api.kvcore.com/v2

# Follow Up Boss (set if CRM_PROVIDER=fub)
FUB_API_KEY=

# ── SMS / Twilio ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                      # Twilio phone number (E.164: +1...) for SMS
ENABLE_SMS_AGENT=true
ENABLE_SMS_IMAGES=true
SEND_BOOKING_CONFIRMATION_SMS=true

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=                     # Neon Postgres connection string
DATABASE_SSL=true
NEON_PROJECT_NAME=                # e.g. real-estate-agent-inbox
NEON_REGION_ID=aws-us-east-1
NEON_DATABASE_NAME=agent_os
NEON_ROLE_NAME=agent_os_app

# ── Email (Iris / Gmail) ──────────────────────────────────────
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_REFRESH_TOKEN=
GMAIL_OAUTH_CLIENT_ID=
TEAM_LEAD_EMAIL=                  # Receiving inbox for Iris email monitoring

# ── Deployment ────────────────────────────────────────────────
PUBLIC_BASE_URL=                  # Deployed URL: https://app.clientdomain.com or Vercel URL
CHANNEL_WEBHOOK_SECRET=           # Random secret — set in Vercel env too (used to auth Vapi webhooks)
NEXT_PUBLIC_AI_SEARCH_BASE_URL=   # Optional: MLS AI search base URL
AI_SEARCH_TENANT_ID=              # Optional: MLS search tenant

# ── Slack Notifications ───────────────────────────────────────
SLACK_WEBHOOK_URL=                # Slack incoming webhook for agent alerts and lead issues

# ── Property Data ─────────────────────────────────────────────
GOOGLE_SHEET_ID=                  # Google Sheet ID for property data (if using Sheets mode)
APIFY_TOKEN=                      # Apify token for Zillow property scraping
