{
  "name": "lumenosis-real-estate-agent-inbox",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run lint",
    "build": "next build",
    "start": "next start",
    "postinstall": "node -e \"const fs=require('fs');const f='package-lock.json';if(!fs.existsSync(f))process.exit(0);const t=fs.readFileSync(f,'utf8');const c=t.replace(/https:\\/\\/artifacts\\.apple\\.com\\/artifactory\\/api\\/npm\\/npm-apple\\//g,'https://registry.npmjs.org/').replace(/https:\\/\\/npm\\.apple\\.com\\//g,'https://registry.npmjs.org/');if(c!==t){fs.writeFileSync(f,c);console.log('postinstall: scrubbed Apple registry URLs from package-lock.json');}\"",
    "lint": "tsc --project tsconfig.lint.json --pretty false",
    "theo:test": "node scripts/test-theo-sms.mjs",
    "theo:twilio:configure": "node scripts/configure-theo-twilio.mjs",
    "aria:provision": "node --import tsx scripts/aria-provision.mjs",
    "aria:provision:dry": "node --import tsx scripts/aria-provision.mjs --dry-run",
    "aria:verify": "node scripts/verify-aria-live.mjs",
    "aria:test": "node --import tsx scripts/test-aria-voice.mjs",
    "aria:followup": "node --import tsx scripts/aria-followup-queue.mjs",
    "aria:backfill": "node --import tsx scripts/backfill-vapi-voice-calls.mjs",
    "sms:backfill": "node scripts/backfill-twilio-sms-events.mjs",
    "import:zillow": "node scripts/import-zillow-apify-properties.mjs",
    "normalize:rental-prices": "node scripts/normalize-rental-prices.mjs",
    "sync:sheets": "node scripts/sync-sheets-to-db.mjs",
    "sync:db-to-sheets": "node scripts/sync-db-to-sheets.mjs",
    "backfill:neon": "python3 scripts/backfill_neon_from_sources.py --json",
    "import:tcad": "python3 scripts/import-tcad-assessor.py --download --json",
    "enrich:ai": "python3 scripts/enrich_neon_ai.py --json",
    "enrich:ai:neighborhood": "python3 scripts/enrich_neon_ai.py --only-neighborhood --json",
    "oracle:fill-rate": "node scripts/fill-rate-oracle.mjs",
    "sync:ghl": "node scripts/sync-events-to-ghl.mjs",
    "setup:neon": "bash scripts/setup-neon.sh",
    "test": "node --import tsx --test \"tests/ts/**/*.test.ts\"",
    "test:py": "pytest tests/"
  },
  "dependencies": {
    "@cartesia/cartesia-js": "^3.2.0",
    "@composio/core": "^0.11.0",
    "@deepgram/sdk": "^5.4.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@neondatabase/serverless": "^1.1.0",
    "@types/dompurify": "^3.0.5",
    "@vapi-ai/server-sdk": "^1.2.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.1",
    "@vercel/speed-insights": "^2.0.0",
    "dompurify": "^3.4.11",
    "ffmpeg-static": "^5.3.0",
    "fish-audio": "^0.1.0",
    "framer-motion": "^12.40.0",
    "googleapis": "^144.0.0",
    "inngest": "^4.7.0",
    "lucide-react": "^1.21.0",
    "next": "^15.3.4",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
